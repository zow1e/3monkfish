NODE_ENV=development
API_PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/petcare
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
PGVECTOR_ENABLED=false
TINYFISH_API_KEY=your-tinyfish-api-key
TINYFISH_DEFAULT_TIMEOUT_MS=30000
TINYFISH_DEFAULT_MAX_PRODUCTS=5
TINYFISH_PROXY_COUNTRY_CODE=SG
TINYFISH_USE_STEALTH_FALLBACK=true
TINYFISH_RAW_DATA_DIR=data/tinyfish/raw
TINYFISH_NORMALIZED_DATA_DIR=data/tinyfish/normalized
