OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_DIMENSIONS=1536
DATABASE_URL=postgresql://user:pass@localhost:5432/petcare
# Project URL (Settings → API) — used to build public Storage URLs for pet photos on the frontend
SUPABASE_URL=https://your-project.supabase.co
# Optional: UUID of a row in public.pets — scopes RAG search/answer to that pet’s species/breed and injects profile into prompts
PET_ID=
PGVECTOR_ENABLED=false
API_PORT=4000
NODE_ENV=development
TINYFISH_RAW_DATA_DIR=./data/tinyfish/raw
TINYFISH_NORMALIZED_DATA_DIR=./data/tinyfish/normalized
