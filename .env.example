OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_DIMENSIONS=1536
DATABASE_URL=postgresql://user:pass@localhost:5432/petcare
# Project URL (Settings → API) — used for Supabase client / public Storage URLs when applicable
SUPABASE_URL=https://your-project.supabase.co
# Anon public key (Settings → API)
SUPABASE_ANON_KEY=
# Same values for the Vite app (only VITE_* is visible in the browser — required for apps/web/app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
# Optional: UUID of a row in public.pets — scopes RAG search/answer to that pet’s species/breed and injects profile into prompts
PET_ID=
PGVECTOR_ENABLED=false
API_PORT=4000
NODE_ENV=development
# Run website + API together (Vite proxies /api → http://127.0.0.1:4000):
#   pnpm dev:stack
# Or: pnpm dev:web   and   pnpm dev:api   in two terminals.
# Optional: browser → API without Vite proxy (e.g. production or split hosts)
# VITE_API_BASE_URL=http://127.0.0.1:4000

# TinyFish listings (see packages/config/src/env.ts). Required for POST /api/listings/scrape (X-API-Key).
TINYFISH_API_KEY=
TINYFISH_DEFAULT_TIMEOUT_MS=30000
TINYFISH_DEFAULT_MAX_PRODUCTS=5
# Optional ISO 3166-1 alpha-2 proxy country, e.g. SG
# TINYFISH_PROXY_COUNTRY_CODE=
TINYFISH_USE_STEALTH_FALLBACK=true
# Optional: defaults to repo `data/tinyfish/raw` and `data/tinyfish/normalized` if unset (see apps/api/src/server.ts).
# TINYFISH_RAW_DATA_DIR=./data/tinyfish/raw
# TINYFISH_NORMALIZED_DATA_DIR=./data/tinyfish/normalized

PGVECTOR_ENABLED=false
API_PORT=4000
NODE_ENV=development
TINYFISH_RAW_DATA_DIR=./data/tinyfish/raw
TINYFISH_NORMALIZED_DATA_DIR=./data/tinyfish/normalized
TINYFISH_API_KEY = sk-tinyfish-J-uCXwTcbQPGTsQ5QMi0DlUuIxmuv2i3
TINYFISH_BASE_URL=https://agent.tinyfish.ai
TINYFISH_DEFAULT_BROWSER_PROFILE=lite
TINYFISH_STEALTH_BROWSER_PROFILE=stealth
TINYFISH_PROXY_ENABLED=false
TINYFISH_PROXY_COUNTRY=SG
